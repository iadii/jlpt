%%=============================================================================
%% 1. HIGH-LEVEL SYSTEM ARCHITECTURE (C4 Context Diagram)
%%=============================================================================
%% Shows the system boundary, external actors, and primary subsystems.

graph TB
    subgraph Clients["🖥️ CLIENT TIER"]
        WebApp["Next.js 16<br/>React 19 + Tailwind v4<br/>SSR / CSR / PWA"]
        MobileApp["React Native<br/>(Future)"]
    end

    subgraph Edge["🌐 EDGE / GATEWAY TIER"]
        CDN["CloudFlare CDN<br/>Static Assets + Audio"]
        Nginx["Nginx<br/>Reverse Proxy<br/>SSL · Rate Limit · gzip"]
    end

    subgraph API["⚙️ API TIER"]
        Django["Django 6.0 + DRF 3.17<br/>8 Domain Apps<br/>JWT Auth · Channels"]
        WS["WebSocket Server<br/>Django Channels<br/>Live Quiz · Notifications"]
    end

    subgraph ML["🧠 ML / NLP TIER"]
        FastAPI["FastAPI ML Service<br/>Smart SRS · Adaptive Quiz<br/>Grammar Check · Chat"]
        Models["ML Models<br/>HLR · IRT · BERT<br/>Whisper · Gemini API"]
    end

    subgraph Async["⚡ ASYNC TIER"]
        Celery["Celery Workers<br/>SRS Recalc · Analytics<br/>Email · ML Batching"]
        Beat["Celery Beat<br/>Scheduled Tasks<br/>Daily SRS · Cleanup"]
    end

    subgraph Data["💾 DATA TIER"]
        PG[("PostgreSQL<br/>Primary OLTP<br/>Models + SRS")]
        Redis[("Redis<br/>Cache · Sessions<br/>Celery Broker · Leaderboard")]
        ES[("Elasticsearch<br/>Japanese Full-Text<br/>Kanji · Vocab · Grammar")]
        S3["S3 / MinIO<br/>Audio · Stroke Images<br/>User Uploads"]
    end

    subgraph Monitoring["📊 OBSERVABILITY"]
        Sentry["Sentry<br/>Error Tracking"]
        Grafana["Prometheus + Grafana<br/>Metrics · Dashboards"]
        Logs["Structured Logging<br/>structlog → ELK/Loki"]
    end

    WebApp -->|HTTPS| CDN
