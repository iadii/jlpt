# CORS
CORS_ORIGINS=http://localhost:3000

# Cookie security (set True in production with HTTPS)
COOKIE_SECURE=False

# External APIs / Datasets
JLPT_VOCAB_API_URL=https://jlpt-vocab-api.vercel.app/api/words
