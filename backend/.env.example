# JLPT Sensei — Environment Variables
# Copy this file to .env and fill in your values

# Django
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=japanese_learning
